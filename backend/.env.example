# Backend environment variables (example)
# Copy this file to backend/.env and fill in values.

# Required for Mistral via Hugging Face Router (OpenAI-compatible)
HF_API_KEY=

# Optional: override the Mistral model
# Default: mistralai/Mistral-7B-Instruct-v0.2:featherless-ai
MISTRAL_MODEL=mistralai/Mistral-7B-Instruct-v0.2:featherless-ai

# Optional: enable local ML fallback if Mistral fails
# Set to 1 only if you installed ML dependencies and have ml/artifacts present.
ENABLE_LOCAL_ML=0
